{
  "expo": {
    "name": "Edara",
    "slug": "edara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0284c7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edara.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Edara needs camera access to take photos of properties and maintenance issues",
        "NSPhotoLibraryUsageDescription": "Edara needs photo library access to upload property and maintenance images",
        "NSFaceIDUsageDescription": "Edara uses Face ID for secure authentication",
        "CFBundleLocalizations": ["en", "ar"],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0284c7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "edara",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization"
    ]
  }
}
